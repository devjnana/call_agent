# HTTP
PORT=3000
# Public URL Plivo hits for webhooks — MUST be reachable HTTPS (not localhost, not *.example placeholders)
BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
# WebSocket origin Plivo uses for audio — same host as BASE_URL, scheme wss://
WS_BASE_URL=wss://YOUR-SUBDOMAIN.ngrok-free.app

# Plivo
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# OpenAI Realtime Translation
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-translate

# Optional: verify Plivo HTTP webhooks (recommended in production)
PLIVO_VALIDATE_SIGNATURES=false

# Timeouts (ms)
CUSTOMER_DIAL_DELAY_MS=400
SESSION_IDLE_TTL_MS=7200000
CALL_SETUP_TIMEOUT_MS=120000

# Optional hashed ID for safety header
OPENAI_SAFETY_IDENTIFIER=
